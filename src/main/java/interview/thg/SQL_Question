String sql =
    "SELECT customer_id, acc_number, branch_id, balance " +
    "FROM Accounts WHERE customer_id = ?";

PreparedStatement ps = c.prepareStatement(sql);
ps.setString(1, customerId);

ResultSet rs = ps.executeQuery();


